//Calculando Desconto
function calculaDesconto(valor, desconto = 10) {
    const valorFinal = valor - (valor * (desconto / 100));
    return valorFinal;
}
console.log(calculaDesconto(100,20));

// Cálculo de média de duas notas
function calculaMedia(nota1, nota2) {
    const media = (nota1 + nota2) / 2;
    return media;
}
